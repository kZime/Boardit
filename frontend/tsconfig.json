{
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    // Enable new JSX transform for React 17+
    "jsx": "react-jsx",
    // Add DOM related types
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    // Add Vite client types
    "types": [
      "vite/client"
    ],
    // Keep others from template...
    "moduleResolution": "node",
  }
}